{
  "name": "@archastro/sdk-nextjs",
  "version": "0.5.1",
  "description": "Next.js extensions for @archastro/sdk",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./edge": {
      "types": "./dist/edge/index.d.ts",
      "import": "./dist/edge/index.js",
      "default": "./dist/edge/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./chat": {
      "types": "./dist/client/chat/index.d.ts",
      "import": "./dist/client/chat/index.js",
      "default": "./dist/client/chat/index.js"
    },
    "./styles.css": "./styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@archastro/sdk": ">=0.4.0",
    "highlight.js": "^11.0.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-markdown": "^10.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remove-markdown": "^0.6.0"
  },
  "peerDependenciesMeta": {
    "react-markdown": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    },
    "remove-markdown": {
      "optional": true
    }
  },
  "devDependencies": {
    "@archastro/sdk": "*",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "highlight.js": "^11.11.1",
    "jsdom": "^23.0.0",
    "next": "^16.1.0",
    "react": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "remove-markdown": "^0.6.3",
    "typescript": "^5.0.0",
    "vitest": "^4.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArchAstro/archastro-js.git",
    "directory": "packages/sdk-nextjs"
  },
  "files": [
    "client",
    "server",
    "edge",
    "dist",
    "styles.css",
    "README.md"
  ]
}
