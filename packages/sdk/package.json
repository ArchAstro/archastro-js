{
  "name": "@archastro/sdk",
  "version": "0.6.0",
  "description": "TypeScript SDK for the ArchAstro Platform API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "docs": "typedoc --options typedoc.json",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:contract": "vitest run --config __tests__/contract/vitest.contract.config.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArchAstro/archastro-js.git",
    "directory": "packages/sdk"
  },
  "dependencies": {
    "ws": "^8.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@archastro/channel-harness": "^0.4.0",
    "@stoplight/prism-cli": "^5.14.2",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.4.0",
    "vitest": "^4.1.3"
  }
}
