{
  "$schema": "https://typedoc.org/schema.json",
  "name": "@archastro/sdk",
  "entryPointStrategy": "expand",
  "entryPoints": ["src"],
  "projectDocuments": ["docs/*.md"],
  "sortEntryPoints": false,
  "tsconfig": "tsconfig.json",
  "exclude": ["src/phx_channel/tests/**"],
  "out": "site",
  "readme": "README.md",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "validation": {
    "notExported": false
  },
  "githubPages": true
}
